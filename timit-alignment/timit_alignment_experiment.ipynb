{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# TIMIT Forced-Alignment Degradation Experiment\n",
    "\n",
    "Tests whether forced alignment breaks when the pronunciation dictionary does not\n",
    "exactly match what is spoken. Three conditions per utterance:\n",
    "\n",
    "| condition | lexicon |\n",
    "|-----------|--------|\n",
    "| canonical | TIMIT global dictionary (rarely matches realisation) |\n",
    "| oracle    | per-file phones extracted from `.phn`/`.wrd` ground truth |\n",
    "| degraded  | oracle with N random phone edits (N = 1…20) |\n",
    "\n",
    "Aligners: **MFA** (TIMIT acoustic model) and **Charsiu**.  \n",
    "Failure = aligner produces no output for the file."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Install dependencies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys\n",
    "\n",
    "subprocess.run(\n",
    "    [\"conda\", \"install\", \"-y\", \"-c\", \"conda-forge\", \"montreal-forced-aligner\"],\n",
    "    check=True,\n",
    ")\n",
    "subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"charsiu\"], check=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!mfa model download acoustic timit"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Configuration — adjust these paths"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "\n",
    "TIMIT_ROOT    = Path(\"/kaggle/input/timit-the-timit-acoustic-phonetic-continuous-speech/TIMIT\")\n",
    "TIMIT_LEXICON = TIMIT_ROOT / \"DOC\" / \"timitdic.txt\"   # check path in your dataset\n",
    "OUTPUT_CSV    = Path(\"/kaggle/working/results.csv\")\n",
    "\n",
    "N_TRIALS    = 10   # trials per (file, n_edits) combination\n",
    "MAX_EDITS   = 20\n",
    "SEED        = 42\n",
    "MFA_MODEL   = \"timit\"  # name as registered in MFA model zoo\n",
    "\n",
    "for p in [TIMIT_ROOT, TIMIT_LEXICON]:\n",
    "    print(p, \"exists:\", p.exists())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. TIMIT parsing utilities"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SILENCE_PHONES = frozenset({\n",
    "    \"h#\", \"pau\", \"epi\",\n",
    "    \"bcl\", \"dcl\", \"gcl\", \"pcl\", \"tcl\", \"kcl\",\n",
    "})\n",
    "\n",
    "TIMIT_61_PHONES = frozenset({\n",
    "    \"iy\", \"ih\", \"eh\", \"ey\", \"ae\", \"aa\", \"aw\", \"ay\", \"ah\", \"ao\",\n",
    "    \"oy\", \"ow\", \"uh\", \"uw\", \"ux\", \"er\", \"ax\", \"ix\", \"axr\", \"ax-h\",\n",
    "    \"jh\", \"ch\", \"b\", \"d\", \"g\", \"p\", \"t\", \"k\", \"dx\", \"s\",\n",
    "    \"sh\", \"z\", \"zh\", \"f\", \"th\", \"v\", \"dh\", \"m\", \"n\", \"ng\",\n",
    "    \"em\", \"nx\", \"en\", \"eng\", \"l\", \"r\", \"w\", \"y\", \"hh\", \"hv\",\n",
    "    \"el\", \"q\",\n",
    "})\n",
    "\n",
    "# phones eligible for random insertion (no silence, no unreleased stops)\n",
    "INSERT_INVENTORY = sorted(TIMIT_61_PHONES - SILENCE_PHONES)\n",
    "\n",
    "# TIMIT phone -> IPA for Charsiu\n",
    "TIMIT_TO_IPA = {\n",
    "    \"iy\": \"iː\", \"ih\": \"ɪ\", \"eh\": \"ɛ\", \"ey\": \"eɪ\", \"ae\": \"æ\",\n",
    "    \"aa\": \"ɑ\",  \"aw\": \"aʊ\", \"ay\": \"aɪ\", \"ah\": \"ʌ\", \"ao\": \"ɔ\",\n",
    "    \"oy\": \"ɔɪ\", \"ow\": \"oʊ\", \"uh\": \"ʊ\",  \"uw\": \"uː\", \"ux\": \"ʉ\",\n",
    "    \"er\": \"ɝ\",  \"ax\": \"ə\",  \"ix\": \"ɨ\",  \"axr\": \"ɚ\", \"ax-h\": \"ə̥\",\n",
    "    \"jh\": \"dʒ\", \"ch\": \"tʃ\",\n",
    "    \"b\": \"b\", \"d\": \"d\", \"g\": \"ɡ\", \"p\": \"p\", \"t\": \"t\", \"k\": \"k\",\n",
    "    \"dx\": \"ɾ\", \"q\": \"ʔ\",\n",
    "    \"s\": \"s\", \"sh\": \"ʃ\", \"z\": \"z\", \"zh\": \"ʒ\",\n",
    "    \"f\": \"f\", \"th\": \"θ\", \"v\": \"v\", \"dh\": \"ð\",\n",
    "    \"m\": \"m\", \"n\": \"n\", \"ng\": \"ŋ\",\n",
    "    \"em\": \"m̩\", \"nx\": \"ɾ̃\", \"en\": \"n̩\", \"eng\": \"ŋ̩\",\n",
    "    \"l\": \"l\", \"r\": \"ɹ\", \"w\": \"w\", \"y\": \"j\",\n",
    "    \"hh\": \"h\", \"hv\": \"ɦ\", \"el\": \"l̩\",\n",
    "}\n",
    "\n",
    "\n",
    "def parse_phn(path):\n",
    "    \"\"\"[(start_sample, end_sample, phone), ...]\"\"\"\n",
    "    entries = []\n",
    "    with open(path) as f:\n",
    "        for line in f:\n",
    "            parts = line.split()\n",
    "            if len(parts) == 3:\n",
    "                entries.append((int(parts[0]), int(parts[1]), parts[2]))\n",
    "    return entries\n",
    "\n",
    "\n",
    "def parse_wrd(path):\n",
    "    \"\"\"[(start_sample, end_sample, word), ...]\"\"\"\n",
    "    entries = []\n",
    "    with open(path) as f:\n",
    "        for line in f:\n",
    "            parts = line.split()\n",
    "            if len(parts) == 3:\n",
    "                entries.append((int(parts[0]), int(parts[1]), parts[2]))\n",
    "    return entries\n",
    "\n",
    "\n",
    "def load_timit_lexicon(path):\n",
    "    \"\"\"Load timitdic.txt -> {word: [[phones], ...]}\"\"\"\n",
    "    lexicon = {}\n",
    "    with open(path) as f:\n",
    "        for line in f:\n",
    "            line = line.strip()\n",
    "            if not line or line.startswith(\";\"):\n",
    "                continue\n",
    "            parts = line.split()\n",
    "            if len(parts) < 2:\n",
    "                continue\n",
    "            word = parts[0].lower().rstrip(\"(0123456789)\")\n",
    "            lexicon.setdefault(word, []).append(parts[1:])\n",
    "    return lexicon\n",
    "\n",
    "\n",
    "def extract_file_lexicon(phn_path, wrd_path):\n",
    "    \"\"\"\n",
    "    Build per-file {word: [[phones], ...]} from ground-truth .phn/.wrd files.\n",
    "\n",
    "    Each phone is assigned to the word whose interval contains the phone's\n",
    "    midpoint.  This handles sandhi without double-counting boundary phones.\n",
    "    Silence/closure phones are excluded.  If the same word type appears more\n",
    "    than once with a different phone sequence, both are kept as alternates.\n",
    "    \"\"\"\n",
    "    phones = parse_phn(phn_path)\n",
    "    words  = parse_wrd(wrd_path)\n",
    "    result = {}\n",
    "    for w_start, w_end, word in words:\n",
    "        word_phones = [\n",
    "            ph for p_start, p_end, ph in phones\n",
    "            if w_start <= (p_start + p_end) // 2 < w_end\n",
    "            and ph not in SILENCE_PHONES\n",
    "        ]\n",
    "        if not word_phones:\n",
    "            continue\n",
    "        existing = result.get(word, [])\n",
    "        if word_phones not in existing:\n",
    "            existing.append(word_phones)\n",
    "        result[word] = existing\n",
    "    return result\n",
    "\n",
    "\n",
    "def iter_timit_files(root):\n",
    "    \"\"\"Yield (wav, phn, wrd) Path triples for every TIMIT utterance.\"\"\"\n",
    "    for wav in sorted(Path(root).rglob(\"*.wav\")):\n",
    "        phn = wav.with_suffix(\".phn\")\n",
    "        wrd = wav.with_suffix(\".wrd\")\n",
    "        if phn.exists() and wrd.exists():\n",
    "            yield wav, phn, wrd\n",
    "\n",
    "\n",
    "def word_sequence(wrd_path):\n",
    "    return [w for _, _, w in parse_wrd(wrd_path)]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Error introduction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import copy, random\n",
    "\n",
    "\n",
    "def insert_phone(phones, rng):\n",
    "    phone = rng.choice(INSERT_INVENTORY)\n",
    "    pos   = rng.randint(0, len(phones))\n",
    "    out   = phones[:]\n",
    "    out.insert(pos, phone)\n",
    "    return out\n",
    "\n",
    "\n",
    "def delete_phone(phones, rng):\n",
    "    if len(phones) <= 1:\n",
    "        return phones[:]\n",
    "    pos = rng.randrange(len(phones))\n",
    "    out = phones[:]\n",
    "    del out[pos]\n",
    "    return out\n",
    "\n",
    "\n",
    "def swap_phones(phones, rng):\n",
    "    if len(phones) < 2:\n",
    "        return phones[:]\n",
    "    pos = rng.randrange(len(phones) - 1)\n",
    "    out = phones[:]\n",
    "    out[pos], out[pos + 1] = out[pos + 1], out[pos]\n",
    "    return out\n",
    "\n",
    "\n",
    "EDIT_OPS = [(\"insert\", insert_phone), (\"delete\", delete_phone), (\"swap\", swap_phones)]\n",
    "\n",
    "\n",
    "def apply_edits(lexicon, n_edits, rng):\n",
    "    \"\"\"\n",
    "    Apply exactly n_edits random phone edits to a copy of lexicon.\n",
    "    Each edit picks a word uniformly at random, picks an op uniformly at random,\n",
    "    and modifies the first pronunciation of that word.\n",
    "    Returns (modified_lexicon, edit_log).\n",
    "    \"\"\"\n",
    "    modified = copy.deepcopy(lexicon)\n",
    "    words    = list(modified.keys())\n",
    "    log      = []\n",
    "    for _ in range(n_edits):\n",
    "        word              = rng.choice(words)\n",
    "        op_name, op_fn    = rng.choice(EDIT_OPS)\n",
    "        before            = modified[word][0][:]\n",
    "        after             = op_fn(before, rng)\n",
    "        modified[word][0] = after\n",
    "        log.append({\"word\": word, \"op\": op_name, \"before\": before, \"after\": after})\n",
    "    return modified, log"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Alignment runners"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import shutil, subprocess, tempfile\n",
    "\n",
    "\n",
    "def _write_dict(lexicon, path):\n",
    "    with open(path, \"w\") as f:\n",
    "        for word, prons in sorted(lexicon.items()):\n",
    "            for phones in prons:\n",
    "                f.write(f\"{word}\\t{' '.join(phones)}\\n\")\n",
    "\n",
    "\n",
    "def run_mfa(wav_path, transcript_words, lexicon, out_dir, acoustic_model=MFA_MODEL):\n",
    "    \"\"\"\n",
    "    Align a single utterance with MFA.  Returns True iff a TextGrid is produced.\n",
    "    \"\"\"\n",
    "    wav_path = Path(wav_path)\n",
    "    out_dir  = Path(out_dir)\n",
    "    out_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    with tempfile.TemporaryDirectory() as tmp:\n",
    "        tmp    = Path(tmp)\n",
    "        corpus = tmp / \"corpus\"\n",
    "        corpus.mkdir()\n",
    "        shutil.copy(wav_path, corpus / wav_path.name)\n",
    "        (corpus / wav_path.with_suffix(\".lab\").name).write_text(\" \".join(transcript_words))\n",
    "        dict_path = tmp / \"lex.dict\"\n",
    "        _write_dict(lexicon, dict_path)\n",
    "        cmd = [\n",
    "            \"mfa\", \"align\", \"--clean\", \"--quiet\",\n",
    "            str(corpus), str(dict_path), acoustic_model, str(out_dir),\n",
    "        ]\n",
    "        try:\n",
    "            subprocess.run(cmd, check=True, capture_output=True)\n",
    "        except (subprocess.CalledProcessError, FileNotFoundError):\n",
    "            return False\n",
    "\n",
    "    tg = out_dir / wav_path.with_suffix(\".TextGrid\").name\n",
    "    return tg.exists() and tg.stat().st_size > 0\n",
    "\n",
    "\n",
    "def _to_ipa(phones):\n",
    "    return [TIMIT_TO_IPA[p] for p in phones if p in TIMIT_TO_IPA]\n",
    "\n",
    "\n",
    "def run_charsiu(wav_path, phones, output_path):\n",
    "    \"\"\"\n",
    "    Align with Charsiu using an explicit phone sequence (TIMIT -> IPA).\n",
    "    Returns True iff a TextGrid is produced.\n",
    "    \"\"\"\n",
    "    from charsiu import charsiu_forced_aligner  # type: ignore\n",
    "\n",
    "    ipa = _to_ipa(phones)\n",
    "    if not ipa:\n",
    "        return False\n",
    "    output_path = Path(output_path)\n",
    "    output_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "    try:\n",
    "        aligner = charsiu_forced_aligner(aligner=\"charsiu/en_w2v2_fc_10ms\")\n",
    "        aligner.serve(audio=str(wav_path), phones=ipa, output=str(output_path))\n",
    "    except Exception:\n",
    "        return False\n",
    "    return output_path.exists() and output_path.stat().st_size > 0"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Experiment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import csv, json\n",
    "\n",
    "FIELDS = [\"file\", \"aligner\", \"condition\", \"n_edits\", \"trial\", \"success\", \"edit_log_json\"]\n",
    "\n",
    "\n",
    "def run_experiment(\n",
    "    timit_root,\n",
    "    timit_lexicon_path,\n",
    "    output_csv,\n",
    "    n_trials=N_TRIALS,\n",
    "    max_edits=MAX_EDITS,\n",
    "    seed=SEED,\n",
    "    max_files=None,\n",
    "):\n",
    "    global_lexicon = load_timit_lexicon(timit_lexicon_path)\n",
    "    rng = random.Random(seed)\n",
    "\n",
    "    output_csv = Path(output_csv)\n",
    "    write_header = not output_csv.exists()\n",
    "\n",
    "    with open(output_csv, \"a\", newline=\"\") as csvfile, \\\n",
    "         tempfile.TemporaryDirectory() as tmp_root:\n",
    "\n",
    "        tmp_root = Path(tmp_root)\n",
    "        writer   = csv.DictWriter(csvfile, fieldnames=FIELDS)\n",
    "        if write_header:\n",
    "            writer.writeheader()\n",
    "\n",
    "        for i, (wav, phn, wrd) in enumerate(iter_timit_files(timit_root)):\n",
    "            if max_files is not None and i >= max_files:\n",
    "                break\n",
    "\n",
    "            file_id  = wav.stem\n",
    "            words    = word_sequence(wrd)\n",
    "            oracle   = extract_file_lexicon(phn, wrd)\n",
    "            canon    = {w: global_lexicon[w] for w in words if w in global_lexicon}\n",
    "            base_dir = tmp_root / file_id\n",
    "\n",
    "            # flat phone list for Charsiu (oracle)\n",
    "            oracle_flat = [p for prons in oracle.values() for ps in prons for p in ps]\n",
    "\n",
    "            def record(condition, n_edits, trial, lexicon, flat_phones, log=\"[]\"):\n",
    "                for aligner, success in [\n",
    "                    (\"mfa\",     run_mfa(wav, words, lexicon,\n",
    "                                        base_dir / \"mfa\" / f\"{condition}_{trial}\")),\n",
    "                    (\"charsiu\", run_charsiu(wav, flat_phones,\n",
    "                                            base_dir / \"charsiu\" / f\"{condition}_{trial}.TextGrid\")),\n",
    "                ]:\n",
    "                    writer.writerow({\n",
    "                        \"file\": file_id, \"aligner\": aligner,\n",
    "                        \"condition\": condition, \"n_edits\": n_edits,\n",
    "                        \"trial\": trial, \"success\": int(success),\n",
    "                        \"edit_log_json\": log,\n",
    "                    })\n",
    "\n",
    "            record(\"canonical\", 0, 0, canon,   oracle_flat)\n",
    "            record(\"oracle\",    0, 0, oracle,   oracle_flat)\n",
    "\n",
    "            for n_edits in range(1, max_edits + 1):\n",
    "                for trial in range(n_trials):\n",
    "                    modified, log = apply_edits(oracle, n_edits, rng)\n",
    "                    mod_flat = [p for prons in modified.values() for ps in prons for p in ps]\n",
    "                    record(\"degraded\", n_edits, trial, modified, mod_flat,\n",
    "                           json.dumps(log))\n",
    "\n",
    "            csvfile.flush()\n",
    "            print(f\"[{i+1}] {file_id}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Smoke test (10 files, 2 trials, 5 max edits)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SMOKE_CSV = Path(\"/kaggle/working/smoke.csv\")\n",
    "run_experiment(TIMIT_ROOT, TIMIT_LEXICON, SMOKE_CSV,\n",
    "               n_trials=2, max_edits=5, max_files=10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Full run"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "run_experiment(TIMIT_ROOT, TIMIT_LEXICON, OUTPUT_CSV)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "df = pd.read_csv(OUTPUT_CSV)\n",
    "\n",
    "# Baseline: canonical vs oracle failure rates\n",
    "base = df[df[\"condition\"].isin([\"canonical\", \"oracle\"])]\n",
    "print(base.groupby([\"aligner\", \"condition\"])[\"success\"].mean().rename(\"success_rate\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "degraded = df[df[\"condition\"] == \"degraded\"]\n",
    "pivot = (\n",
    "    degraded.groupby([\"aligner\", \"n_edits\"])[\"success\"]\n",
    "    .mean()\n",
    "    .unstack(\"aligner\")\n",
    ")\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "for aligner in pivot.columns:\n",
    "    ax.plot(pivot.index, 1 - pivot[aligner], marker=\"o\", label=aligner)\n",
    "ax.set_xlabel(\"Number of random phone edits\")\n",
    "ax.set_ylabel(\"Alignment failure rate\")\n",
    "ax.set_title(\"Alignment failure vs. lexicon edit distance\")\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"/kaggle/working/failure_curve.png\", dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary table\n",
    "table = (\n",
    "    degraded.groupby([\"n_edits\", \"aligner\"])[\"success\"]\n",
    "    .agg(failure_rate=lambda x: round(1 - x.mean(), 3), n=len)\n",
    "    .reset_index()\n",
    ")\n",
    "print(table.to_string(index=False))"
   ]
  }
